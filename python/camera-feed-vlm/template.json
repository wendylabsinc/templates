{
    "name": "camera-feed-vlm",
    "description": "Live camera feed + vision-language chat: ask questions about what the camera sees (moondream2 on Jetson GPU, CPU fallback)",
    "variables": [
        {
            "name": "APP_ID",
            "description": "Application identifier",
            "type": "string",
            "required": true,
            "prompt": "App ID"
        },
        {
            "name": "PORT",
            "description": "HTTP port",
            "type": "integer",
            "default": 3006,
            "prompt": "HTTP port",
            "validate": { "min": 1, "max": 65535 }
        }
    ]
}
