{
    "name": "camera-feed-yolo",
    "description": "Live camera feed with YOLOv8 COCO object detection",
    "variables": [
        {
            "name": "APP_ID",
            "description": "Application identifier",
            "type": "string",
            "required": true,
            "prompt": "App ID"
        },
        {
            "name": "PORT",
            "description": "HTTP port",
            "type": "integer",
            "default": 3005,
            "prompt": "HTTP port",
            "validate": { "min": 1, "max": 65535 }
        }
    ]
}
