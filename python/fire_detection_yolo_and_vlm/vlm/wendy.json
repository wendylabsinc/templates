{
    "appId": "sh.wendy.examples.vlm",
    "version": "1.0.0",
    "language": "python",
    "entitlements": [
        {"type": "gpu"},
        {"type": "network", "mode": "host"}
    ],
    "readiness": {
        "tcpSocket": { "port": 8090 },
        "timeoutSeconds": 60
    },
    "hooks": {
        "postStart": {
            "cli": "wendy utils open-browser http://${WENDY_HOSTNAME}:8090"
        }
    }
}
