{
  "appId": "wendybox-alberta-demo",
  "entitlements": [
    { "type": "gpu" },
    { "type": "network", "mode": "host" },
    { "type": "bluetooth" },
    { "type": "video" },
    { "type": "audio" },
    { "type": "persist", "name": "albert-models", "path": "/models" },
    { "type": "persist", "name": "albert-yolo-models", "path": "/yolo-models" },
    { "type": "persist", "name": "albert-logs", "path": "/logs" }
  ],
  "readiness": {
    "tcpSocket": { "port": 5702, "timeoutSeconds": 180 }
  },
  "hooks": {
    "postStart": {
      "cli": "open http://${WENDY_HOSTNAME}:5702"
    }
  }
}
