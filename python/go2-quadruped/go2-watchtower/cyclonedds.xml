<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
    <Domain id="any">
        <General>
            <Interfaces>
                <!-- This NIC must carry the 192.168.123.0/24 address on the deploy host.
                     On the Go2's onboard Jetson it's eth0 (default); on other devices
                     check `ip addr` and pass --var NETWORK_INTERFACE=<NIC> to wendy init. -->
                <NetworkInterface name="{{.NETWORK_INTERFACE}}" priority="default" multicast="default" />
            </Interfaces>
            <AllowMulticast>true</AllowMulticast>
            <MaxMessageSize>65500B</MaxMessageSize>
        </General>
        <Discovery>
            <ParticipantIndex>auto</ParticipantIndex>
            <!-- Each child process here creates its own DDS participant.
                 Default cap is 9 (10 slots) — we run 11+ children
                 (uwb_bridge, uwb_filter, video_bridge, audio_bridge,
                 mic_node, dog_marker, vision_detector, vision_tracker,
                 pose_bridge, lidar_filter, foxglove_bridge, …) and the
                 11th onwards fails with "Failed to find a free
                 participant index for domain 0". 60 leaves comfortable
                 headroom for additional bridges. -->
            <MaxAutoParticipantIndex>60</MaxAutoParticipantIndex>
        </Discovery>
    </Domain>
</CycloneDDS>
