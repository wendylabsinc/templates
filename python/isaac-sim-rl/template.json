{
    "name": "isaac-sim-rl",
    "description": "Isaac Sim / IsaacLab RL training app with RSL-RL, persistent logs, checkpoints, and sim-to-real handoff notes",
    "variables": [
        {
            "name": "APP_ID",
            "description": "Application identifier",
            "type": "string",
            "required": true,
            "prompt": "App ID"
        },
        {
            "name": "ROBOT_PROFILE",
            "description": "Robot or training profile",
            "type": "string",
            "default": "unitree-go2-flat",
            "prompt": "Robot profile"
        },
        {
            "name": "TASK_ID",
            "description": "IsaacLab task id to train. Use auto to derive it from ROBOT_PROFILE.",
            "type": "string",
            "default": "auto",
            "prompt": "IsaacLab task id"
        },
        {
            "name": "EXPERIMENT_NAME",
            "description": "RSL-RL experiment folder under /logs/rsl_rl. Use auto to derive it from ROBOT_PROFILE.",
            "type": "string",
            "default": "auto",
            "prompt": "Experiment name"
        },
        {
            "name": "NUM_ENVS",
            "description": "Parallel IsaacLab environments",
            "type": "integer",
            "default": 1024,
            "prompt": "Number of environments",
            "validate": { "min": 1, "max": 16384 }
        },
        {
            "name": "MAX_ITERATIONS",
            "description": "Training iterations",
            "type": "integer",
            "default": 20000,
            "prompt": "Max iterations",
            "validate": { "min": 1 }
        },
        {
            "name": "ISAAC_SIM_IMAGE",
            "description": "Isaac Sim container image",
            "type": "string",
            "default": "nvcr.io/nvidia/isaac-sim:5.1.0",
            "prompt": "Isaac Sim image"
        },
        {
            "name": "ISAACLAB_REF",
            "description": "IsaacLab git tag or branch",
            "type": "string",
            "default": "v2.3.2",
            "prompt": "IsaacLab ref"
        }
    ]
}
