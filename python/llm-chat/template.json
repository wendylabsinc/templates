{
    "name": "llm-chat",
    "description": "Local Gemma 4 chat UI backed by llama.cpp",
    "variables": [
        {
            "name": "APP_ID",
            "description": "Application identifier",
            "type": "string",
            "required": true,
            "prompt": "App ID"
        },
        {
            "name": "PORT",
            "description": "Primary HTTP port",
            "type": "integer",
            "default": 3010,
            "prompt": "HTTP port",
            "validate": { "min": 1, "max": 65535 }
        },
        {
            "name": "GEMMA_MODEL",
            "description": "Gemma 4 model preset or Hugging Face GGUF selector. Use auto, nano, orin, agx-orin, thor, or repo:quant.",
            "type": "string",
            "default": "auto",
            "prompt": "Gemma model"
        },
        {
            "name": "LLAMA_CONTEXT_SIZE",
            "description": "llama.cpp context window",
            "type": "integer",
            "default": 4096,
            "prompt": "Context size",
            "validate": { "min": 512, "max": 262144 }
        },
        {
            "name": "LLAMA_GPU_LAYERS",
            "description": "GPU layers to offload; 99 means all practical layers for these models",
            "type": "integer",
            "default": 99,
            "prompt": "GPU layers",
            "validate": { "min": 0, "max": 999 }
        },
        {
            "name": "LLAMA_THREADS",
            "description": "CPU threads for llama.cpp",
            "type": "integer",
            "default": 6,
            "prompt": "CPU threads",
            "validate": { "min": 1, "max": 256 }
        },
        {
            "name": "LLAMA_REASONING",
            "description": "llama.cpp reasoning mode. Use off for chat UI responses or on to expose Gemma 4 thinking.",
            "type": "string",
            "default": "off",
            "prompt": "Reasoning mode"
        }
    ]
}
