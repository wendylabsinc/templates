{
    "appId": "{{.APP_ID}}",
    "version": "0.1.0",
    "entitlements": [
        {
            "type": "network",
            "mode": "host"
        },
        {
            "type": "gpu"
        },
        {
            "type": "persist",
            "name": "{{.APP_ID}}-models",
            "path": "/models"
        },
        {
            "type": "persist",
            "name": "{{.APP_ID}}-openwebui",
            "path": "/data"
        }
    ],
    "readiness": {
        "tcpSocket": {
            "port": {{.PORT}}
        },
        "timeoutSeconds": 300
    },
    "hooks": {
        "postStart": {
            "cli": "wendy utils open-browser http://${WENDY_HOSTNAME}:{{.PORT}}"
        }
    }
}
