{
    "appId": "{{.APP_ID}}",
    "version": "0.1.0",
    "entitlements": [
        { "type": "usb" },
        { "type": "network", "mode": "host" }
    ],
    "readiness": {
        "tcpSocket": { "port": {{.PORT}} },
        "timeoutSeconds": 60
    },
    "hooks": {
        "postStart": {
            "cli": "open http://${WENDY_HOSTNAME}:{{.PORT}}"
        }
    }
}
