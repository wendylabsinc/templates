{
    "appId": "{{.APP_ID}}",
    "version": "0.1.0",
    "entitlements": [
        {
            "type": "network",
            "mode": "host"
        },
        {
            "type": "audio"
        }{{if eq .INFERENCE_MODE "local"}},
        {
            "type": "gpu"
        }{{end}}
    ],
    "readiness": {
        "tcpSocket": { "port": {{.PORT}} },
        "timeoutSeconds": 60
    }
}
