{
    "appId": "{{.APP_ID}}",
    "version": "0.1.0",
    "language": "swift",
    "platform": "darwin",
    "run": {
        "args": [
            "--host", "0.0.0.0",
            "--port", "{{.PORT}}",
            "--model", "{{.MODEL_ID}}",
            "--default-max-tokens", "{{.MAX_TOKENS}}"
        ]
    },
    "readiness": {
        "tcpSocket": { "port": {{.PORT}} },
        "timeoutSeconds": 60
    }
}
